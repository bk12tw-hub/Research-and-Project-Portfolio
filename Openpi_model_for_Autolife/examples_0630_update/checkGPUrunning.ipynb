    "import numpy as np\n",
    "from openpi.training import config as _config\n",
    "from openpi.policies import policy_config\n",
    "from openpi.shared import download\n",
    "\n",
    "state = np.load(\"/tmp/joint_states.npy\")\n",
    "head_image = np.load(\"/tmp/head_image.npy\")\n",
    "\n",
    "example = {\n",
    "    \"observation/exterior_image_1_left\": head_image.astype(np.uint8),        # real head camera\n",
    "    \"observation/wrist_image_left\":      np.zeros((224, 224, 3), dtype=np.uint8),  # zeros for now\n",
    "\n",
    "    \"observation/joint_position\":        state[:7].astype(np.float64),       # real joint positions\n",
    "    \"observation/joint_velocity\":        np.zeros(7, dtype=np.float64),      # zeros for now\n",
    "    \"observation/gripper_position\":      state[7:8].astype(np.float64),      # real gripper\n",
    "\n",
    "    \"prompt\": \"pick up the red cup\",\n",
    "}--policy.dir=\"/home/lenovo/.cache/openpi/openpi-assets/checkpoints/pi0_base/\"\n",
    "\n",
    "\n",
    "\n",
    "# add BEFORE policy.infer(example)\n",
    "print(\"\\n=== INPUT VERIFICATION ===\")\n",
    "for key, val in example.items():\n",
    "    if isinstance(val, np.ndarray):\n",
    "        print(f\"{key}:\")\n",
    "        print(f\"  shape : {val.shape}\")\n",
    "        print(f\"  min   : {val.min():.4f}\")\n",
    "        print(f\"  max   : {val.max():.4f}\")\n",
    "        print(f\"  mean  : {val.mean():.4f}\")\n",
    "        if val.min() == val.max():\n",
    "            print(f\"  ⚠️  UNIFORM VALUE — this input is not varying!\")\n",
    "    else:\n",
    "        print(f\"{key}: {val}\")\n",
    "\n",
    "config         = _config.get_config(\"pi05_droid\")\n",
    "checkpoint_dir = download.maybe_download(\"gs://openpi-assets/checkpoints/pi05_droid\")\n",
    "policy         = policy_config.create_trained_policy(config, checkpoint_dir)\n",
    "\n",
    "# run twice with different inputs and compare\n",
    "action1 = policy.infer(example)[\"actions\"]\n",
    "\n",
    "# manually change one joint slightly\n",
    "example2 = dict(example)\n",
    "example2[\"observation/joint_position\"] = example[\"observation/joint_position\"] + 0.5\n",
    "action2 = policy.infer(example2)[\"actions\"]\n",
    "\n",
    "print(\"\\n=== OUTPUT COMPARISON ===\")\n",
    "print(f\"Action 1 first step: {action1[0].round(4)}\")\n",
    "print(f\"Action 2 first step: {action2[0].round(4)}\")\n",
    "print(f\"Difference         : {(action1[0] - action2[0]).round(4)}\")\n",
    "\n",
    "if np.allclose(action1, action2, atol=1e-3):\n",
    "    print(\"❌ IDENTICAL outputs — inputs not reaching the model!\")\n",
    "else:\n",
    "    print(\"✅ Different outputs — model IS responding to input changes\")"
   ]

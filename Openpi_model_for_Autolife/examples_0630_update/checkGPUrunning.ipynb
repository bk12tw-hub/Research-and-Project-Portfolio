    "import json\n",
    "\n",
    "def analyze_joints(file_path, indices=[18, 19]):\n",
    "    # Initialize a dictionary to store results for each index\n",
    "    stats = {i: {\"min\": float('inf'), \"max\": float('-inf')} for i in indices}\n",
    "    \n",
    "    with open(file_path, 'r') as f:\n",
    "        for line_num, line in enumerate(f, 1):\n",
    "            try:\n",
    "                data = json.loads(line)\n",
    "                positions = data[\"joints\"][\"position\"]\n",
    "                \n",
    "                for i in indices:\n",
    "                    val = positions[i]\n",
    "                    if val < stats[i][\"min\"]: stats[i][\"min\"] = val\n",
    "                    if val > stats[i][\"max\"]: stats[i][\"max\"] = val\n",
    "                    \n",
    "            except (KeyError, IndexError, json.JSONDecodeError):\n",
    "                continue # Skip corrupted or empty lines\n",
    "\n",
    "    return stats\n",
    "\n",
    "# --- Run the Analysis ---\n",
    "file_name = \"/home/lenovo/Downloads/white_doll_dataset/095/joints/data.jsonl\"\n",
    "results = analyze_joints(file_name, indices=[18, 19])\n",
    "\n",
    "for idx, val in results.items():\n",
    "    print(f\"Index {idx}:\")\n",
    "    print(f\"  Min: {val['min']:.4f}\")\n",
    "    print(f\"  Max: {val['max']:.4f}\")\n",
    "    print(f\"  Range: {val['max'] - val['min']:.4f}\")\n",
    "    print(\"-\" * 20)"
   ]

    "import os\n",
    "import shutil\n",
    "import random\n",
    "\n",
    "def combine_and_randomize(folder1, folder2, output_folder):\n",
    "    # 1. Gather all subfolders from both directories\n",
    "    # We filter to make sure we only grab actual directories\n",
    "    subfolders = []\n",
    "    \n",
    "    if os.path.exists(folder1):\n",
    "        subfolders.extend([os.path.join(folder1, f) for f in os.listdir(folder1) if os.path.isdir(os.path.join(folder1, f))])\n",
    "    else:\n",
    "        print(f\"Warning: {folder1} does not exist.\")\n",
    "        \n",
    "    if os.path.exists(folder2):\n",
    "        subfolders.extend([os.path.join(folder2, f) for f in os.listdir(folder2) if os.path.isdir(os.path.join(folder2, f))])\n",
    "    else:\n",
    "        print(f\"Warning: {folder2} does not exist.\")\n",
    "\n",
    "    if not subfolders:\n",
    "        print(\"No subfolders found to process.\")\n",
    "        return\n",
    "\n",
    "    # 2. Randomize the order of the gathered subfolders\n",
    "    random.shuffle(subfolders)\n",
    "\n",
    "    # 3. Create the output directory if it doesn't exist\n",
    "    os.makedirs(output_folder, exist_ok=True)\n",
    "\n",
    "    # 4. Copy and rename them into the output folder\n",
    "    print(# Just a separator for clean logs\n",
    "    \"--- Starting Copy and Rename Process ---\")\n",
    "    for index, original_path in enumerate(subfolders, start=1):\n",
    "        new_name = f\"episode_{index}\"\n",
    "        destination_path = os.path.join(output_folder, new_name)\n",
    "        \n",
    "        print(f\"Copying: {original_path} -> {destination_path}\")\n",
    "        shutil.copytree(original_path, destination_path)\n",
    "        \n",
    "    print(f\"\\nSuccess! All folders combined and randomized into '{output_folder}'.\")\n",
    "\n",
    "# --- Configuration ---\n",
    "# Replace these paths with your actual folder locations\n",
    "FOLDER_A = \"/home/lenovo/Downloads/pick_cube_task_20more_16more\"\n",
    "FOLDER_B = \"/home/lenovo/Downloads/2026-06-16/pick_cube_task\"\n",
    "COMBINED_FOLDER = \"/home/lenovo/Downloads/pick_cube_task_20more_16more_20more\"\n",
    "\n",
    "# Run the function\n",
    "combine_and_randomize(FOLDER_A, FOLDER_B, COMBINED_FOLDER)"
   ]

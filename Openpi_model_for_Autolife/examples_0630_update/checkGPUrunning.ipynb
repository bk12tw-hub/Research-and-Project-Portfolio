    "print(f\"Total frames   : {len(ds)}\")\n",
    "print(f\"Total episodes : {ds.num_episodes}\")\n",
    "\n",
    "# check columns via hf_dataset instead\n",
    "print(f\"Columns        : {ds.hf_dataset.column_names}\")\n",
    "\n",
    "# check first sample to see what keys exist\n",
    "sample = ds[0]\n",
    "print(f\"\\nFirst sample keys: {list(sample.keys())}\")\n",
    "for key, val in sample.items():\n",
    "    if hasattr(val, 'shape'):\n",
    "        print(f\"  {key}: shape={tuple(val.shape)} dtype={val.dtype}\")\n",
    "    else:\n",
    "        print(f\"  {key}: {val}\")\n",
    "\n",
    "# check for NaN/Inf\n",
    "print(\"\\nChecking all samples for NaN/Inf...\")\n",
    "errors = []\n",
    "for i in range(len(ds)):\n",
    "    try:\n",
    "        sample = ds[i]\n",
    "\n",
    "        for key in [\"state\", \"actions\", \"observation.state\",\n",
    "                    \"action\", \"observation/state\"]:\n",
    "            if key in sample:\n",
    "                arr = np.array(sample[key])\n",
    "                if np.any(np.isnan(arr)) or np.any(np.isinf(arr)):\n",
    "                    errors.append(f\"Frame {i} key={key}: NaN/Inf found!\")\n",
    "                if i == 0:\n",
    "                    print(f\"  {key}: shape={arr.shape} \"\n",
    "                          f\"min={arr.min():.3f} max={arr.max():.3f}\")\n",
    "\n",
    "        if i % 200 == 0:\n",
    "            print(f\"  Checked {i}/{len(ds)}...\", end=\"\\r\")\n",
    "\n",
    "    except Exception as e:\n",
    "        errors.append(f\"Frame {i}: {e}\")\n",
    "\n",
    "print(f\"\\nChecked {len(ds)} frames\")\n",
    "if errors:\n",
    "    print(f\"❌ {len(errors)} errors found:\")\n",
    "    for e in errors[:10]:\n",
    "        print(f\"  {e}\")\n",
    "else:\n",
    "    print(\"✅ No NaN/Inf found — dataset looks clean!\")\n",

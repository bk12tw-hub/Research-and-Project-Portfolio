    "import os\n",
    "import shutil\n",
    "from pathlib import Path\n",
    "\n",
    "def combine_and_relabel(source_dirs, target_dir):\n",
    "    # Create the target directory if it doesn't exist\n",
    "    target_path = Path(target_dir)\n",
    "    target_path.mkdir(parents=True, exist_ok=True)\n",
    "    \n",
    "    print(f\"Target Directory: {target_path.absolute()}\")\n",
    "    \n",
    "    current_session_idx = 1\n",
    "    \n",
    "    for source in source_dirs:\n",
    "        source_path = Path(source)\n",
    "        if not source_path.exists():\n",
    "            print(f\"Warning: Source {source} not found. Skipping.\")\n",
    "            continue\n",
    "            \n",
    "        print(f\"Processing source: {source_path.name}\")\n",
    "        \n",
    "        # Get all subdirectories (sessions), sorted to maintain chronological order if possible\n",
    "        sessions = sorted([d for d in source_path.iterdir() if d.is_dir()])\n",
    "        \n",
    "        for session_folder in sessions:\n",
    "            # Create the new name with leading zeros (e.g., session_001)\n",
    "            new_name = f\"session_{current_session_idx:03d}\"\n",
    "            dest_path = target_path / new_name\n",
    "            \n",
    "            # Copy (or move) the folder\n",
    "            print(f\"  Relabeling: {session_folder.name} -> {new_name}\")\n",
    "            shutil.copytree(session_folder, dest_path)\n",
    "            \n",
    "            current_session_idx += 1\n",
    "\n",
    "    print(f\"\\nDone! Combined {current_session_idx - 1} sessions into {target_dir}\")\n",
    "\n",
    "# --- Configuration ---\n",
    "folders_to_combine = [\n",
    "    \"/home/lenovo/Downloads/2026-04-30__\",\n",
    "    \"/home/lenovo/Downloads/2026-04-30-full\"\n",
    "]\n",
    "output_folder = \"/home/lenovo/Downloads/2026-04-30_full\"\n",
    "\n",
    "combine_and_relabel(folders_to_combine, output_folder)"
   ]
  },

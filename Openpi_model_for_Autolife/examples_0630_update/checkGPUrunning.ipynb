    "# fix_state_shape.py — run with openpi venv (Python 3.11)\n",
    "from datasets import load_dataset\n",
    "import numpy as np\n",
    "\n",
    "REPO_ID = \"Chi-chu/myautolife_data\"\n",
    "\n",
    "ds = load_dataset(REPO_ID, download_mode=\"force_redownload\")\n",
    "print(f\"State shape in dataset: {np.array(ds['train'][0]['state']).shape}\")\n",
    "print(f\"Actions shape         : {np.array(ds['train'][0]['action']).shape}\")\n",
    "\n",
    "def fix_state(example):\n",
    "    state = np.array(example[\"state\"])\n",
    "    if state.shape == (7,):\n",
    "        # pad with zero gripper if missing\n",
    "        print(\"⚠️  Padding state from (7,) to (8,)\")\n",
    "        example[\"state\"] = np.concatenate(\n",
    "            [state, np.zeros(1)]).astype(np.float32)\n",
    "    return example\n",
    "\n",
    "ds = ds.map(fix_state)\n",
    "print(f\"Fixed state shape: {np.array(ds['train'][0]['state']).shape}\")\n",
    "\n",
    "ds.push_to_hub(REPO_ID)\n",
    "print(\"✅ Pushed fixed dataset!\")"
   ]
